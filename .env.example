# ──────────────────────────────────────────────────────────────────────────
#  Jarvis configuration. Copy this file to ".env" and fill it in.
#  The .env file is gitignored and never leaves your machine.
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED — the master passphrase that encrypts your secret vault (tokens, keys).
# Choose a long, unique phrase. If you lose it, the vault cannot be decrypted.
# Treat this like the key to a safe.
JARVIS_MASTER_KEY=change-me-to-a-long-random-passphrase

# ── LLM brain ──────────────────────────────────────────────────────────────
# "openrouter" = many free + premium models (e.g. Gemma 4). "gemini" = Google free tier.
# "ollama" = fully local (most private). "auto" = openrouter > gemini > ollama by key presence.
JARVIS_LLM_PROVIDER=auto

# For the Ollama (local) brain. Install from https://ollama.com, then:
#   ollama pull llama3.2          (chat model)
#   ollama pull nomic-embed-text  (embeddings for memory)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# For the Gemini (cloud, free-tier) brain. Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Note: gemini-2.0-flash often has 0 free-tier quota; gemini-2.5-flash works on the free tier.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

# For OpenRouter (many free + premium models). Get a key: https://openrouter.ai/keys
# Free models have ":free" in the id; browse at https://openrouter.ai/models?max_price=0
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# ── Google (Gmail + Calendar) — Phase 1 ─────────────────────────────────────
# Create a "Desktop app" OAuth client at console.cloud.google.com (see SETUP-GOOGLE.md),
# then paste the Client ID and Client Secret here. After that, run /connect in the CLI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Surfaces (optional) ─────────────────────────────────────────────────────
# Telegram bot token from @BotFather. Leave blank to use the CLI only.
TELEGRAM_BOT_TOKEN=
# Your Telegram numeric user ID — LOCKS the bot to you only (security: a bot token
# is effectively public). Leave blank; run `npm run telegram`, message the bot, and
# it replies with your ID. Put that ID here and restart.
TELEGRAM_OWNER_ID=

# ── Storage ─────────────────────────────────────────────────────────────────
# Where the local encrypted database lives. Default: ./data/jarvis.db
JARVIS_DB_PATH=./data/jarvis.db
