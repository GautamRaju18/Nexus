# Dependencies
node_modules/

# Local data — NEVER commit. Your memory, audit log, and encrypted vault live here.
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# Secrets — never commit anything that holds keys.
.env
.env.*
!.env.example
*.env
*.key
# A bare "env" (no dot) slips past ".env"; ignore stray variants too.
/env
env.txt
env.bak

# Build / editor
dist/
.DS_Store
*.log
.weblog.txt
.weberr.txt
